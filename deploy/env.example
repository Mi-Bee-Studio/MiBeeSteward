# MiBee Steward environment variables
# Copy to /etc/default/mibee-steward and adjust as needed
#
# Usage:
#   sudo cp deploy/env.example /etc/default/mibee-steward
#   sudo nano /etc/default/mibee-steward   # edit values
#   sudo systemctl restart mibee-steward

# Server port (default: 8080)
MIBEE_SERVER_PORT=8080

# Server host (default: 0.0.0.0)
MIBEE_SERVER_HOST=0.0.0.0

# SQLite database path (default: ./data/mibee.db)
MIBEE_DATABASE_PATH=/opt/mibee-steward/data/mibee.db

# JWT secret — MUST change in production (min 32 characters)
# MIBEE_AUTH_JWT_SECRET=your-strong-secret-here

# Initial admin password — MUST set for production
# MIBEE_AUTH_INITIAL_ADMIN_PASSWORD=your-admin-password

# Log level: debug, info, warn, error (default: info)
# MIBEE_LOG_LEVEL=info

# Log format: json, text (default: text)
# MIBEE_LOG_FORMAT=text

# Cookie settings for HTTPS
# MIBEE_AUTH_COOKIE_SECURE=true
# MIBEE_AUTH_COOKIE_DOMAIN=steward.example.com
